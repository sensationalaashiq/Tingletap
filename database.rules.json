{
  "rules": {
    ".read": false,
    ".write": false,

    "status": {
      // FIX 10: Presence status is non-sensitive; any auth user may READ.
      // Each user may WRITE only their own status entry.
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "room_presence": {
      // FIX-PERF-1: Per-room presence node. Each room only contains its own
      // members, eliminating the O(N²) bandwidth cost of the global status/ listener.
      // Reads are room-scoped (any auth user may read a room's presence list).
      // Writes are uid-scoped (each user writes only their own entry).
      "$roomId": {
        ".read": "auth != null",
        "$uid": {
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },

    "roomCounts": {
      // Room-member counts are maintained by client-side presence writes.
      // FIX: previously had no write grant, so every client write here was
      // silently rejected by the root ".write": false — counts never populated.
      // Each user may write only their own entry within a room.
      ".read": "auth != null",
      "$roomId": {
        "$uid": {
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },

    "broadcasts": {
      "rj": {
        // FIX 10 (hardened): Root write is now gated to the live broadcast's
        // owner via the `rjUid` field written by the client on Go Live
        // (see BroadcastPanel.jsx `set(ref(rtdb, 'broadcasts/rj'), { rjUid: myUid, ... })`).
        // - Creating a fresh session (no data yet) is allowed for any auth user
        //   (the client only exposes "Go Live" to users with the RJ badge; RTDB
        //   has no access to that role flag without custom claims, so the app-level
        //   gate remains the first line of defense for who may start a broadcast).
        // - Once a session exists, only the matching rjUid may write/update/end it,
        //   which also covers bulk cleanup (remove connections/listeners) and
        //   top-level metadata writes (listenerCount) since RTDB cascades this
        //   root grant down to every descendant path for that same host.
        ".read": "auth != null",
        ".write": "auth != null && (!data.exists() || auth.uid === data.child('rjUid').val())",

        "connections": {
          "$uid": {
            ".read": "auth != null",
            // Own uid (listener's own ICE candidates) OR the live RJ (writes into a listener's slot)
            ".write": "auth != null && (auth.uid === $uid || auth.uid === root.child('broadcasts/rj/rjUid').val())"
          }
        },
        "listeners": {
          ".read": "auth != null",
          "$uid": {
            ".write": "auth != null && auth.uid === $uid"
          }
        },
        "speakers": {
          ".read": "auth != null",
          "$uid": {
            ".write": "auth != null && (auth.uid === $uid || auth.uid === root.child('broadcasts/rj/rjUid').val())"
          }
        },
        "speakerConnections": {
          ".read": "auth != null",
          "$uid": {
            ".write": "auth != null && (auth.uid === $uid || auth.uid === root.child('broadcasts/rj/rjUid').val())"
          }
        },
        "joinRequests": {
          ".read": "auth != null",
          "$uid": {
            ".write": "auth != null && auth.uid === $uid"
          }
        },
        "youtube": {
          ".read": "auth != null",
          // Only the live RJ drives playback state; listeners only ever read this node.
          ".write": "auth != null && auth.uid === root.child('broadcasts/rj/rjUid').val()"
        },
        "songQueue": {
          ".read": "auth != null",
          "$uid": {
            // A user may write their own song request; the live RJ may approve/reject/skip/remove any
            ".write": "auth != null && (auth.uid === $uid || auth.uid === root.child('broadcasts/rj/rjUid').val())"
          }
        },
        "announcements": {
          ".read": "auth != null",
          // Only the live RJ posts/deletes announcements
          ".write": "auth != null && auth.uid === root.child('broadcasts/rj/rjUid').val()",
          "$announcementId": {
            ".write": "auth != null && auth.uid === root.child('broadcasts/rj/rjUid').val()"
          }
        }
      },
      "public": {
        "$broadcastId": {
          ".read": "auth != null",
          // Root write (create/update/end) restricted to the session owner once it exists.
          ".write": "auth != null && (!data.exists() || auth.uid === data.child('session/hostUid').val())",
          "connections": {
            "$uid": {
              ".read": "auth != null",
              ".write": "auth != null && (auth.uid === $uid || auth.uid === root.child('broadcasts/public/' + $broadcastId + '/session/hostUid').val())"
            }
          },
          "listeners": {
            ".read": "auth != null",
            "$uid": {
              ".write": "auth != null && auth.uid === $uid"
            }
          }
        }
      }
    },

    "calls": {
      "$callId": {
        ".read": "auth != null && (data.child('callerId').val() == auth.uid || data.child('recipientId').val() == auth.uid)",
        ".write": "auth != null && (!data.exists() || data.child('callerId').val() == auth.uid || data.child('recipientId').val() == auth.uid)"
      }
    },

    "siteVisitors": {
      ".read": "auth != null",
      "active": {
        "$sid": {
          // FIX C-04: Previously ".write": true (unauthenticated flood attack possible).
          // Now requires auth so anonymous external scripts cannot pollute visitor data.
          ".write": "auth != null && auth.uid === $sid",
          ".validate": "newData.hasChildren(['device','browser','joinedAt'])"
        }
      },
      "daily": {
        "$date": {
          // FIX C-04: Previously ".write": true — now requires authentication.
          ".write": "auth != null"
        }
      }
    },

    "privateMessages": {
      "$conversationId": {
        // FIX 10: Conversation IDs are uid1_uid2 (UIDs separated by _).
        // .contains() checks that auth.uid appears as a substring.
        // Firebase UIDs are 28-char alphanumeric with no underscores, making
        // false positives from substring matching extremely unlikely.
        // A fully-secure implementation would use an explicit participants
        // map: data.child('participants').child(auth.uid).exists()
        ".read": "auth != null && $conversationId.contains(auth.uid)",
        ".write": "auth != null && $conversationId.contains(auth.uid)",
        "messages": {
          "$messageId": {
            ".write": "auth != null && auth.uid == newData.child('senderId').val()"
          }
        }
      }
    }
  }
}

