{
  "rules": {
    ".read": false,
    ".write": false,

    "status": {
      ".read": "auth != null",
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "broadcasts": {
      "rj": {
        ".read": "auth != null",
        ".write": "auth != null",
        "connections": {
          "$uid": {
            ".read": "auth != null",
            ".write": "auth != null"
          }
        },
        "listeners": {
          ".read": "auth != null",
          "$uid": {
            ".write": "auth != null"
          }
        },
        "speakers": {
          ".read": "auth != null",
          "$uid": {
            ".write": "auth != null"
          }
        },
        "joinRequests": {
          ".read": "auth != null",
          "$uid": {
            ".write": "auth != null"
          }
        },
        "youtube": {
          ".read": "auth != null",
          ".write": "auth != null"
        }
      },
      "public": {
        "$broadcastId": {
          ".read": "auth != null",
          ".write": "auth != null",
          "session": {
            ".read": "auth != null",
            ".write": "auth != null"
          },
          "connections": {
            "$uid": {
              ".read": "auth != null",
              ".write": "auth != null"
            }
          },
          "listeners": {
            ".read": "auth != null",
            "$uid": {
              ".write": "auth != null"
            }
          }
        }
      }
    }
  }
}
