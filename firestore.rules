rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════════════════════════════════════
    // HELPER FUNCTIONS
    // ══════════════════════════════════════════════════════════════════════

    // Fetch the role field from a user document.
    // Defaults to 'user' if the document does not yet exist (new registration flow).
    function getUserRole(uid) {
      return exists(/databases/$(database)/documents/users/$(uid))
        ? get(/databases/$(database)/documents/users/$(uid)).data.role
        : 'user';
    }

    // Role predicates
    function isOwner() {
      return request.auth != null && getUserRole(request.auth.uid) == 'owner';
    }
    function isAdmin() {
      return request.auth != null && getUserRole(request.auth.uid) == 'admin';
    }
    function isModerator() {
      return request.auth != null && getUserRole(request.auth.uid) == 'moderator';
    }
    function isStaff() {
      return request.auth != null
        && getUserRole(request.auth.uid) in ['owner', 'admin', 'moderator'];
    }
    function isOwnerOrAdmin() {
      return request.auth != null
        && getUserRole(request.auth.uid) in ['owner', 'admin'];
    }
    function isGuest() {
      return request.auth != null && getUserRole(request.auth.uid) == 'guest';
    }
    function isRegistered() {
      // Registered = any authenticated user with a real (non-guest) role
      return request.auth != null
        && getUserRole(request.auth.uid) in ['owner', 'admin', 'moderator', 'user', 'badge'];
    }

    // ── Status checks ────────────────────────────────────────────────────

    function isUserBanned(uid) {
      return exists(/databases/$(database)/documents/users/$(uid))
        && get(/databases/$(database)/documents/users/$(uid)).data.isBanned == true;
    }

    function isUserMuted(uid) {
      return exists(/databases/$(database)/documents/users/$(uid))
        && get(/databases/$(database)/documents/users/$(uid)).data.mutedInfo.isMuted == true;
    }

    function isUserKickedFromRoom(uid, roomId) {
      return exists(/databases/$(database)/documents/rooms/$(roomId)/kickedUsers/$(uid));
    }

    function isUserBlocked(blockerId, blockedId) {
      return exists(/databases/$(database)/documents/users/$(blockerId))
        && get(/databases/$(database)/documents/users/$(blockerId)).data.blockedUsers != null
        && blockedId in get(/databases/$(database)/documents/users/$(blockerId)).data.blockedUsers;
    }

    // ── Access helpers ───────────────────────────────────────────────────

    // Staff can always message (no mute/ban applies to them).
    // Non-staff: not banned, target not banned.
    function canSendMessageToUser(targetUid) {
      return isStaff()
        || (!isUserBanned(request.auth.uid) && !isUserBanned(targetUid));
    }

    function canSendFriendRequest(targetUid) {
      return isStaff()
        || (isRegistered() && !isUserBanned(request.auth.uid) && !isUserBanned(targetUid))
        || (isGuest() && getUserRole(targetUid) == 'guest');
    }

    function canDeleteMessage(messageData) {
      return isStaff() || messageData.uid == request.auth.uid;
    }

    // ── Field-level write validation (own-profile updates) ───────────────

    // Fields any authenticated user may update on their own profile.
    function allowedSelfFields() {
      return [
        'friends', 'lastLogin', 'isOnline', 'fontPreferences',
        'messageFontPreferences', 'usernameFontPreferences',
        'darkMode', 'selectedTheme', 'displayName', 'photoURL',
        'gender', 'country', 'status', 'bio', 'profession',
        'blockedUsers', 'settings', 'lastSeen', 'preferences',
        'avatar', 'username', 'email', 'createdAt', 'updatedAt',
        'lastIP', 'lastIPUpdate', 'lastDeviceId', 'lastDeviceInfo',
        'lastUserAgent', 'fcmToken', 'pushToken', 'notificationPreferences',
        'lastActivity', 'typingStatus'
      ];
    }

    // Fields that may ONLY be written by staff (TingleBot or manual moderation).
    function staffOnlyFields() {
      return [
        'role', 'isBanned', 'mutedInfo', 'badge', 'banReason',
        'bannedBy', 'bannedAt', 'unbannedAt', 'unbannedBy',
        'autoModHistory', 'autoModStats', 'kickedFrom',
        'warningsCount', 'trustScore'
      ];
    }

    function onlyUpdatingAllowedSelfFields() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly(allowedSelfFields());
    }

    function onlyUpdatingAllowedStaffFields() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly(allowedSelfFields().concat(staffOnlyFields()));
    }

    // ── Message validation ───────────────────────────────────────────────

    function validateMessageContent() {
      return request.resource.data.keys().hasAll(['text', 'uid', 'displayName', 'createdAt']);
    }

    // ── Friend request validation ────────────────────────────────────────

    function validateFriendRequest() {
      return request.resource.data.keys().hasAll(
               ['senderId', 'receiverId', 'senderName', 'status', 'createdAt'])
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.senderId != request.resource.data.receiverId;
    }

    function validateFriendRequestUpdate() {
      return request.resource.data.status in ['accepted', 'rejected']
        && request.auth.uid == resource.data.receiverId
        && resource.data.status == 'pending';
    }

    // ══════════════════════════════════════════════════════════════════════
    // USERNAMES
    // Public read allows username→email lookup before auth (login flow).
    // ══════════════════════════════════════════════════════════════════════
    match /usernames/{username} {
      allow read: if true;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.uid;
      allow update: if request.auth != null
        && (request.auth.uid == resource.data.uid || isStaff());
      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.uid || isStaff());
    }

    // ══════════════════════════════════════════════════════════════════════
    // USERS
    // Read:   staff always; own doc always; any non-banned authenticated user.
    // Create: own document on registration (registered or guest).
    // Update: own profile (restricted field set); staff can update anyone
    //         within their hierarchy with no field restriction.
    // Delete: owner only.
    // ══════════════════════════════════════════════════════════════════════
    match /users/{userId} {

      allow read: if request.auth != null && (
        isStaff()
        || request.auth.uid == userId
        || !isUserBanned(request.auth.uid)
      );

      // New account creation — both registered (email string) and guest (email null).
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.uid == request.auth.uid
        && (request.resource.data.email is string
            || request.resource.data.email == null);

      // Own-profile update: only whitelisted self-fields; banned users cannot update.
      allow update: if request.auth != null
        && request.auth.uid == userId
        && exists(/databases/$(database)/documents/users/$(userId))
        && onlyUpdatingAllowedSelfFields()
        && !isUserBanned(request.auth.uid);

      // Staff updating any user — hierarchy enforced:
      //   owner  → may update anyone
      //   admin  → may update non-owners
      //   moderator → may update non-owners and non-admins
      // No field restriction for staff (covers TingleBot automod writes).
      allow update: if isStaff()
        && exists(/databases/$(database)/documents/users/$(userId))
        && (
          isOwner()
          || (isAdmin() && getUserRole(userId) != 'owner')
          || (isModerator()
              && getUserRole(userId) != 'owner'
              && getUserRole(userId) != 'admin')
        );

      allow delete: if isOwner();
    }

    // ══════════════════════════════════════════════════════════════════════
    // FRIEND REQUESTS
    // ══════════════════════════════════════════════════════════════════════
    match /friendRequests/{requestId} {
      allow read: if request.auth != null && (
        isStaff()
        || resource.data.senderId == request.auth.uid
        || resource.data.receiverId == request.auth.uid
      );
      allow create: if request.auth != null
        && validateFriendRequest()
        && canSendFriendRequest(request.resource.data.receiverId);
      allow update: if request.auth != null
        && validateFriendRequestUpdate()
        && !isUserBanned(request.auth.uid);
      allow delete: if request.auth != null && (
        isStaff()
        || resource.data.senderId == request.auth.uid
        || resource.data.receiverId == request.auth.uid
      );
    }

    // ══════════════════════════════════════════════════════════════════════
    // ROOMS
    // ══════════════════════════════════════════════════════════════════════
    match /rooms/{roomId} {
      allow read: if request.auth != null;
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isOwnerOrAdmin();

      // ── Messages ──────────────────────────────────────────────────────
      // Read: staff always; others must not be banned or kicked from this room.
      // Create:
      //   • Staff — unrestricted (bypass all mutes/bans for moderation notices).
      //   • Everyone else — must not be banned, muted, or kicked; uid must match auth.
      // Update: staff or own message (not banned).
      // Delete: staff or own message.
      match /messages/{messageId} {
        allow read: if request.auth != null && (
          isStaff()
          || (!isUserBanned(request.auth.uid)
              && !isUserKickedFromRoom(request.auth.uid, roomId))
        );

        allow create: if request.auth != null && (
          isStaff()
          || (
            request.resource.data.uid == request.auth.uid
            && !isUserBanned(request.auth.uid)
            && !isUserMuted(request.auth.uid)
            && !isUserKickedFromRoom(request.auth.uid, roomId)
            && validateMessageContent()
          )
        );

        allow update: if request.auth != null && (
          isStaff()
          || (resource.data.uid == request.auth.uid && !isUserBanned(request.auth.uid))
        );

        allow delete: if request.auth != null && (
          isStaff()
          || canDeleteMessage(resource.data)
        );
      }

      // ── Kicked users list ─────────────────────────────────────────────
      // Staff manage kicks; the kicked user can read their own record so the
      // client can detect the kick and navigate them out of the room.
      match /kickedUsers/{kickedUserId} {
        allow read: if isStaff()
          || (request.auth != null && request.auth.uid == kickedUserId);
        allow create, update, delete: if isStaff();
      }

      // ── TingleBot automod claim documents ─────────────────────────────
      // Atomic claim: first staff client to write this doc "wins" and is the
      // sole enforcer for that message. Moderators must be able to write here.
      match /automod/{claimId} {
        allow read, write: if isStaff();
      }
    }

    // ══════════════════════════════════════════════════════════════════════
    // MODLOGS — TingleBot v3.0 violation log
    // Staff write on every automod action; staff read for admin panel.
    // Only owner/admin may delete log entries.
    // ══════════════════════════════════════════════════════════════════════
    match /modLogs/{logId} {
      allow create: if isStaff();
      allow read: if isStaff();
      allow update: if isOwnerOrAdmin();
      allow delete: if isOwnerOrAdmin();
    }

    // ══════════════════════════════════════════════════════════════════════
    // MODERATION LOGS (legacy collection — kept alongside modLogs)
    // ══════════════════════════════════════════════════════════════════════
    match /moderationLogs/{document=**} {
      allow read, write: if isStaff();
    }

    // ══════════════════════════════════════════════════════════════════════
    // BANNED IPs
    // All authenticated users (including guests) must be able to read this
    // collection so the client-side IP ban check runs on app startup.
    // Only owner/admin may create or modify ban entries.
    // ══════════════════════════════════════════════════════════════════════
    match /bannedIPs/{ipId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isOwnerOrAdmin();
    }

    // ══════════════════════════════════════════════════════════════════════
    // BANNED DEVICES
    // Same access pattern as bannedIPs.
    // ══════════════════════════════════════════════════════════════════════
    match /bannedDevices/{deviceId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isOwnerOrAdmin();
    }

    // ══════════════════════════════════════════════════════════════════════
    // WARNINGS & ANNOUNCEMENTS
    // All authenticated users read (popup shown to everyone).
    // Staff create/update (moderators can post announcements).
    // Owner/admin delete.
    // ══════════════════════════════════════════════════════════════════════
    match /warnings_announcements/{announcementId} {
      allow read: if request.auth != null;
      allow create, update: if isStaff();
      allow delete: if isOwnerOrAdmin();
    }

    // ══════════════════════════════════════════════════════════════════════
    // PRIVATE MESSAGES
    // Guests may only DM other guests.
    // Registered users may DM anyone who is not banned or blocked.
    // Staff (owner/admin) may DM anyone.
    // ══════════════════════════════════════════════════════════════════════
    match /privateMessages/{messageId} {
      allow read: if request.auth != null && (
        isStaff()
        || (request.auth.uid in resource.data.participants
            && !isUserBanned(request.auth.uid))
      );
      allow create: if request.auth != null && (
        isStaff()
        || (
          request.auth.uid in request.resource.data.participants
          && request.resource.data.senderId == request.auth.uid
          && !isUserBanned(request.auth.uid)
          && !isUserBanned(request.resource.data.receiverId)
          && !isUserBlocked(request.resource.data.receiverId, request.auth.uid)
          && (
            (isRegistered() && canSendMessageToUser(request.resource.data.receiverId))
            || (isGuest() && getUserRole(request.resource.data.receiverId) == 'guest')
          )
        )
      );
      allow update: if request.auth != null && (
        isStaff()
        || (request.auth.uid in resource.data.participants
            && !isUserBanned(request.auth.uid))
      );
      allow delete: if request.auth != null && (
        isStaff()
        || resource.data.senderId == request.auth.uid
      );
    }

    // ══════════════════════════════════════════════════════════════════════
    // REPORTS
    // ══════════════════════════════════════════════════════════════════════
    match /reports/{reportId} {
      allow create: if request.auth != null
        && request.resource.data.reportedBy.uid == request.auth.uid
        && !isUserBanned(request.auth.uid);
      allow read: if request.auth != null && (
        isStaff()
        || resource.data.reportedBy.uid == request.auth.uid
      );
      allow update, delete: if isStaff();
    }

    // ══════════════════════════════════════════════════════════════════════
    // CALLS — WebRTC signalling
    // ══════════════════════════════════════════════════════════════════════
    match /calls/{callId} {
      allow read: if request.auth != null && (
        isStaff()
        || request.auth.uid == resource.data.callerId
        || request.auth.uid == resource.data.recipientId
      );
      allow create: if request.auth != null
        && request.resource.data.callerId == request.auth.uid
        && !isUserBanned(request.auth.uid)
        && canSendMessageToUser(request.resource.data.recipientId);
      allow update, delete: if request.auth != null && (
        isStaff()
        || request.auth.uid == resource.data.callerId
        || request.auth.uid == resource.data.recipientId
      );

      match /offerCandidates/{docId} {
        allow read, write: if request.auth != null && !isUserBanned(request.auth.uid);
      }
      match /answerCandidates/{docId} {
        allow read, write: if request.auth != null && !isUserBanned(request.auth.uid);
      }
    }

    // ══════════════════════════════════════════════════════════════════════
    // WHISPERS
    // ══════════════════════════════════════════════════════════════════════
    match /whispers/{whisperId} {
      allow read: if request.auth != null && (
        isStaff()
        || resource.data.senderId == request.auth.uid
        || resource.data.receiverId == request.auth.uid
      );
      allow create: if request.auth != null && (
        isStaff()
        || (
          request.resource.data.senderId == request.auth.uid
          && !isUserBanned(request.auth.uid)
          && !isUserBlocked(request.resource.data.receiverId, request.auth.uid)
          && canSendMessageToUser(request.resource.data.receiverId)
        )
      );
      allow update: if request.auth != null && (
        isStaff()
        || (resource.data.senderId == request.auth.uid && !isUserBanned(request.auth.uid))
      );
      allow delete: if isStaff();
    }

    // ══════════════════════════════════════════════════════════════════════
    // NOTIFICATIONS
    // ══════════════════════════════════════════════════════════════════════
    match /notifications/{notificationId} {
      allow read: if request.auth != null && (
        isStaff() || resource.data.userId == request.auth.uid
      );
      allow create: if request.auth != null && (
        isStaff() || request.resource.data.userId == request.auth.uid
      );
      allow update: if request.auth != null && (
        isStaff() || resource.data.userId == request.auth.uid
      );
      allow delete: if request.auth != null && (
        isStaff() || resource.data.userId == request.auth.uid
      );
    }

    // ══════════════════════════════════════════════════════════════════════
    // CONVERSATIONS (DM thread metadata)
    // Guests may only create conversations with other guests.
    // ══════════════════════════════════════════════════════════════════════
    match /conversations/{conversationId} {
      allow read: if request.auth != null && (
        isStaff()
        || (request.auth.uid in resource.data.participants
            && !isUserBanned(request.auth.uid))
      );
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants
        && !isUserBanned(request.auth.uid)
        && (
          isRegistered()
          || (isGuest()
              && request.resource.data.participants.hasOnly(
                   request.resource.data.participants
                 ))
        );
      allow update: if request.auth != null && (
        isStaff()
        || (request.auth.uid in resource.data.participants
            && !isUserBanned(request.auth.uid))
      );
      allow delete: if isStaff();

      match /messages/{messageId} {
        allow read: if request.auth != null && (
          isStaff()
          || (request.auth.uid in
                get(/databases/$(database)/documents/conversations/$(conversationId))
                  .data.participants
              && !isUserBanned(request.auth.uid))
        );
        allow create: if request.auth != null && (
          isStaff()
          || (
            request.resource.data.senderId == request.auth.uid
            && !isUserBanned(request.auth.uid)
            && request.auth.uid in
                 get(/databases/$(database)/documents/conversations/$(conversationId))
                   .data.participants
            && (
              isRegistered()
              || (isGuest()
                  && getUserRole(request.resource.data.receiverId) == 'guest')
            )
          )
        );
        allow update: if request.auth != null && (
          isStaff()
          || (request.auth.uid in
                get(/databases/$(database)/documents/conversations/$(conversationId))
                  .data.participants
              && !isUserBanned(request.auth.uid))
        );
        allow delete: if isStaff()
          || (request.auth != null && resource.data.senderId == request.auth.uid);
      }
    }

    // ══════════════════════════════════════════════════════════════════════
    // BLOCKS
    // Staff (owner/admin/moderator) cannot be blocked by anyone.
    // ══════════════════════════════════════════════════════════════════════
    match /blocks/{blockId} {
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.blockerId
        && !isUserBanned(request.auth.uid)
        && !isStaff()   // staff can't be blocked (checked via blockedId role below)
        && getUserRole(request.resource.data.blockedId) != 'owner'
        && getUserRole(request.resource.data.blockedId) != 'admin'
        && getUserRole(request.resource.data.blockedId) != 'moderator';
      allow read: if request.auth != null && (
        isStaff() || request.auth.uid == resource.data.blockerId
      );
      allow delete: if request.auth != null && (
        isStaff() || request.auth.uid == resource.data.blockerId
      );
    }

    // ══════════════════════════════════════════════════════════════════════
    // PRESENCE
    // ══════════════════════════════════════════════════════════════════════
    match /presence/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && (request.auth.uid == userId || isStaff());
    }

    // ══════════════════════════════════════════════════════════════════════
    // GLOBAL STYLING
    // Any authenticated user reads all styles (to render everyone's custom look).
    // A user writes only their own style doc; staff may write any.
    // ══════════════════════════════════════════════════════════════════════
    match /globalUsernameStyles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && (request.auth.uid == userId || isStaff());
    }

    match /globalMessageStyles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && (request.auth.uid == userId || isStaff());
    }

    // ══════════════════════════════════════════════════════════════════════
    // GUEST SESSIONS
    // Guests create/update their own session document.
    // Staff read/write all; owner/admin delete stale sessions.
    // ══════════════════════════════════════════════════════════════════════
    match /guestSessions/{sessionId} {
      allow read: if isStaff()
        || (request.auth != null && request.auth.uid == sessionId);
      allow create, update: if request.auth != null
        && request.auth.uid == sessionId;
      allow delete: if isOwnerOrAdmin();
    }

    // ══════════════════════════════════════════════════════════════════════
    // RADIO STATIONS
    // ══════════════════════════════════════════════════════════════════════
    match /radioStations/{stationId} {
      allow read: if request.auth != null;
      allow write: if isStaff();
    }

    // ══════════════════════════════════════════════════════════════════════
    // GAMES
    // ══════════════════════════════════════════════════════════════════════
    match /games/{gameId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isStaff();

      match /participants/{participantId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.auth.uid == participantId
          && !isUserBanned(request.auth.uid);
        allow update: if request.auth != null
          && (request.auth.uid == participantId || isStaff());
        allow delete: if request.auth != null
          && (request.auth.uid == participantId || isStaff());
      }
    }

    // ══════════════════════════════════════════════════════════════════════
    // LEADERBOARDS
    // ══════════════════════════════════════════════════════════════════════
    match /leaderboards/{leaderboardId} {
      allow read: if request.auth != null;
      allow write: if isStaff();
    }

    // ══════════════════════════════════════════════════════════════════════
    // ACHIEVEMENTS
    // ══════════════════════════════════════════════════════════════════════
    match /achievements/{achievementId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
        && (resource.data.userId == request.auth.uid || isStaff());
      allow delete: if isStaff();
    }

    // ══════════════════════════════════════════════════════════════════════
    // BADGES
    // ══════════════════════════════════════════════════════════════════════
    match /badges/{document=**} {
      allow read: if request.auth != null;
      allow write: if isOwnerOrAdmin();
    }

    // ══════════════════════════════════════════════════════════════════════
    // UPLOADS
    // ══════════════════════════════════════════════════════════════════════
    match /uploads/{uploadId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uploadedBy == request.auth.uid
        && !isUserBanned(request.auth.uid);
      allow update: if request.auth != null
        && (resource.data.uploadedBy == request.auth.uid || isStaff());
      allow delete: if request.auth != null
        && (resource.data.uploadedBy == request.auth.uid || isStaff());
    }

    // ══════════════════════════════════════════════════════════════════════
    // FEEDBACK
    // ══════════════════════════════════════════════════════════════════════
    match /feedback/{feedbackId} {
      allow create: if request.auth != null
        && request.resource.data.submittedBy == request.auth.uid
        && !isUserBanned(request.auth.uid);
      allow read: if request.auth != null && (
        isStaff() || resource.data.submittedBy == request.auth.uid
      );
      allow update, delete: if isStaff();
    }

    // ══════════════════════════════════════════════════════════════════════
    // MEDIA / COSMETICS
    // ══════════════════════════════════════════════════════════════════════
    match /emojis/{emojiId} {
      allow read: if request.auth != null;
      allow write: if isStaff();
    }

    match /stickers/{stickerId} {
      allow read: if request.auth != null;
      allow write: if isStaff();
    }

    match /themes/{themeId} {
      allow read: if request.auth != null;
      allow write: if isStaff();
    }

    // ══════════════════════════════════════════════════════════════════════
    // USER PREFERENCES
    // ══════════════════════════════════════════════════════════════════════
    match /userPreferences/{userId} {
      allow read, write: if request.auth != null
        && (request.auth.uid == userId || isStaff());
    }

    // ══════════════════════════════════════════════════════════════════════
    // SETTINGS & CONFIG
    // App-wide settings (room config, TingleBot config, feature flags).
    // Owner/admin write; all staff read (moderators need to read these for the
    // admin panel and TingleBot SettingsSidebar integration).
    // ══════════════════════════════════════════════════════════════════════
    match /settings/{document=**} {
      allow read: if isStaff();
      allow write: if isOwnerOrAdmin();
    }

    match /config/{document=**} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    // ══════════════════════════════════════════════════════════════════════
    // ADMIN-ONLY COLLECTIONS
    // ══════════════════════════════════════════════════════════════════════
    match /admin/{document=**} {
      allow read, write: if isOwnerOrAdmin();
    }

    match /statistics/{document=**} {
      allow read: if isStaff();
      allow write: if isOwnerOrAdmin();
    }

    match /analytics/{document=**} {
      allow read, write: if isStaff();
    }

    match /systemLogs/{document=**} {
      allow read, write: if isStaff();
    }

    match /bannedWords/{document=**} {
      allow read: if isStaff();
      allow write: if isOwnerOrAdmin();
    }

    // ══════════════════════════════════════════════════════════════════════
    // CATCH-ALL FALLBACK
    // Owner & Admin can read/write any collection not explicitly matched above.
    // This prevents legitimate admin operations from being denied on new
    // collections added during development.
    // ══════════════════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if isOwnerOrAdmin();
    }

  }
}
